---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MotionReveal from '../../components/MotionReveal';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <main class="relative overflow-hidden">
    <div class="absolute inset-0 -z-20 bg-zinc-950"></div>

    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_28%),radial-gradient(circle_at_top_right,rgba(168,85,247,0.14),transparent_26%),radial-gradient(circle_at_bottom,rgba(59,130,246,0.10),transparent_34%)]"></div>

    <div class="absolute inset-0 -z-10 opacity-30 [background-image:linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] [background-size:42px_42px]"></div>

    <section class="mx-auto max-w-6xl px-6 py-10 md:py-14">
      <div class="mx-auto max-w-4xl">
        <div class="relative rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-[0_20px_80px_rgba(0,0,0,0.35)] md:p-8">
          
          <div class="absolute inset-0 -z-10 rounded-[28px] bg-gradient-to-br from-cyan-400/8 via-transparent to-violet-400/8"></div>

          {post.data.thumbnail && (
            <MotionReveal client:load>
              <div class="overflow-hidden rounded-[24px] border border-white/10 bg-white/5">
                <img
                  src={post.data.thumbnail}
                  alt={post.data.title}
                  class="h-full max-h-[420px] w-full object-cover transition duration-500 hover:scale-[1.015]"
                />
              </div>
            </MotionReveal>
          )}

          <MotionReveal client:load delay={0.08}>
            <div class={post.data.thumbnail ? 'mt-8' : ''}>
              <div class="flex items-center justify-between">
                <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">
                  {post.data.date.toLocaleDateString('en-GB', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </p>

                {post.data.repo && (
                  <a
                    href={post.data.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]"
                  >
                    <img
                      src="https://cdn.simpleicons.org/github/ffffff"
                      alt="GitHub"
                      class="h-3.5 w-3.5"
                    />
                    <span>View repo</span>
                  </a>
                )}
              </div>

              <h1 class="mt-3 py-2 bg-gradient-to-r from-cyan-300 via-blue-400 to-violet-400 bg-clip-text text-4xl font-semibold tracking-tight text-transparent sm:text-5xl">
                {post.data.title}
              </h1>

              <p class="mt-5 max-w-3xl text-base leading-8 text-zinc-400 sm:text-lg">
                {post.data.description}
              </p>

              <div class="mt-6 flex flex-wrap gap-2.5">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </MotionReveal>

          <MotionReveal client:load delay={0.16} mode="onLoad">
            <article
              class="prose prose-invert prose-zinc mt-12 max-w-none
                prose-headings:scroll-mt-24
                prose-headings:font-semibold
                prose-headings:tracking-tight
                prose-h1:text-4xl
                prose-h2:mt-12 prose-h2:text-2xl
                prose-h3:mt-8 prose-h3:text-xl
                prose-p:text-zinc-300 prose-p:leading-8
                prose-li:text-zinc-300 prose-li:leading-7
                prose-strong:text-white
                prose-code:text-cyan-300
                prose-pre:border prose-pre:border-white/10 prose-pre:bg-black/30
                prose-blockquote:border-l-white/10 prose-blockquote:text-zinc-400
                prose-img:rounded-2xl prose-img:border prose-img:border-white/10
                prose-a:text-cyan-300 prose-a:no-underline hover:prose-a:text-cyan-200 hover:prose-a:underline"
            >
              <Content />
            </article>
          </MotionReveal>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>