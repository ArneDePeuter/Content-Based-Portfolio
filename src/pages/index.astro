---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card';
import Timeline from '../components/Timeline';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date - a.data.date);

const work_posts = posts.filter(post => post.data.work === true);
const other_posts = posts.filter(post => post.data.work === false);

const timelineEntries = await getCollection('timeline');

const timelineItems = timelineEntries.map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  organization: entry.data.organization,
  description: entry.data.description,
  start: entry.data.start,
  end: entry.data.end,
  category: entry.data.category,
  href: entry.data.relatedPost ? `/blog/${entry.data.relatedPost}` : undefined,
  hrefLabel: entry.data.relatedPostLabel,
}));

const currentYear = new Date().getFullYear();
---

<BaseLayout title="Portfolio - Arne De Peuter" description="Projects, writing, and background.">
  <main>
    <section class="mx-auto max-w-6xl px-6 pt-6" id="hero">
      <Hero />
    </section>

    <section class="mx-auto max-w-6xl px-6" id="timeline">
      <div class="my-10 border-t border-white/8"></div>
      <Timeline client:visible items={timelineItems} />
    </section>

    <section class="mx-auto max-w-6xl px-6" id="blog">
      <div class="my-10 border-t border-white/8"></div>
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-3xl font-semibold text-white">Work Experience</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {work_posts.map((post) => (
    <Card
      client:visible
      title={post.data.title}
      description={post.data.description}
      href={`/posts/${post.id}`}
      date={post.data.date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })}
      tags={post.data.tags}
      thumbnail={post.data.thumbnail}
    />
  ))}
</div>
    </section>

    <section class="mx-auto max-w-6xl px-6" id="projects">
      <div class="my-10 border-t border-white/8"></div>
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-3xl font-semibold text-white">Projects</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {other_posts.map((post) => (
    <Card
      client:visible
      title={post.data.title}
      description={post.data.description}
      href={`/posts/${post.id}`}
      date={post.data.date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })}
      tags={post.data.tags}
      thumbnail={post.data.thumbnail}
    />
  ))}
</div>
    </section>
  </main>

  <div class="mt-10 border-t border-white/10"></div>

<footer class="mx-auto max-w-6xl px-6 pb-10 pt-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-sm text-zinc-400">
          © {currentYear} Arne De Peuter.
        </p>
        <p class="mt-2 text-sm text-zinc-500">
          Open to contact via email or LinkedIn.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          href="mailto:arne@depeuter.org"
          class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:-translate-y-0.5 hover:border-cyan-400/40 hover:bg-cyan-400/15"
        >
          Email
        </a>

        <a
          href="https://linkedin.com/in/arne-de-peuter"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:-translate-y-0.5 hover:border-cyan-400/40 hover:bg-cyan-400/15"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>
