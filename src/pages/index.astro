---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card';
import Timeline from '../components/Timeline';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date - a.data.date);

const work_posts = posts.filter(post => post.data.work === true);
const other_posts = posts.filter(post => post.data.work === false);

const timelineEntries = await getCollection('timeline');

const timelineItems = timelineEntries.map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  organization: entry.data.organization,
  description: entry.data.description,
  start: entry.data.start,
  end: entry.data.end,
  category: entry.data.category,
  href: entry.data.relatedPost ? `/blog/${entry.data.relatedPost}` : undefined,
  hrefLabel: entry.data.relatedPostLabel,
}));
---

<BaseLayout title="Portfolio - Arne De Peuter" description="Projects, writing, and background.">
  <main>
    <section class="mx-auto max-w-6xl px-6 py-6" id="hero">
      <Hero />
    </section>

    <section class="mx-auto max-w-6xl px-6 py-6" id="timeline">
      <Timeline client:load items={timelineItems} />
    </section>

    <section class="mx-auto max-w-6xl px-6 py-6" id="blog">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-3xl font-semibold text-white">Work Experience</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {work_posts.map((post) => (
    <Card
      client:load
      title={post.data.title}
      description={post.data.excerpt}
      href={`/posts/${post.id}`}
      date={post.data.date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })}
      tags={post.data.tags}
      thumbnail={post.data.thumbnail}
    />
  ))}
</div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-6" id="projects">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-3xl font-semibold text-white">Projects</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {other_posts.map((post) => (
    <Card
      client:load
      title={post.data.title}
      description={post.data.excerpt}
      href={`/posts/${post.id}`}
      date={post.data.date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })}
      tags={post.data.tags}
      thumbnail={post.data.thumbnail}
    />
  ))}
</div>
    </section>
  </main>
</BaseLayout>