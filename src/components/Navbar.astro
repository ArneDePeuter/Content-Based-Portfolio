---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/70 backdrop-blur-2xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="group inline-flex items-center gap-3">
      <span class="inline-block h-3 w-3 rounded-full bg-cyan-400 shadow-[0_0_20px_rgba(34,211,238,0.8)]"></span>
      <span class="text-sm font-semibold uppercase tracking-[0.24em] text-zinc-100 transition group-hover:text-cyan-300">
        Portfolio
      </span>
    </a>

    <nav class="flex items-center gap-2 sm:gap-3">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-full border border-transparent px-4 py-2 text-sm text-zinc-300 transition duration-200 hover:border-white/10 hover:bg-white/5 hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
