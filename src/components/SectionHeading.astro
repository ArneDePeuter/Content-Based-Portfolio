---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-2xl">
  {eyebrow && (
    <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">
      {eyebrow}
    </p>
  )}
  <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
    {title}
  </h2>
  {description && <p class="mt-2 text-sm leading-7 text-zinc-400">{description}</p>}
</div>