---
import MotionReveal from './MotionReveal';

const techStack = [
  { name: 'Python', icon: 'python' },
  { name: 'FastAPI', icon: 'fastapi' },
  { name: 'Pandas', icon: 'pandas' },
  { name: 'NumPy', icon: 'numpy' },
  { name: 'scikit-learn', icon: 'scikitlearn' },
  { name: 'PyTorch', icon: 'pytorch' },
  { name: 'Dlt', icon: 'dlthub'},
  { name: 'LangGraph', icon: 'langgraph'},
  { name: 'C', icon: 'c'},
  { name: 'C++', icon: 'c++'},
  { name: 'Rust', icon: 'rust'},
  { name: 'Ollama', icon: 'ollama'},
  { name: 'React', icon: 'react'},
  { name: 'Docker', icon: 'docker' },
  { name: 'Kubernetes', icon: 'kubernetes'},
  { name: 'PostgreSQL', icon: 'postgresql' },
  { name: 'Auth0', icon: 'auth0'},
  { name: 'Nginx', icon: 'nginx'},
  { name: 'mosquitto', icon: 'eclipsemosquitto'},
  { name: 'Git', icon: 'git' },
  { name: 'Linux', icon: 'linux' },

];
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-20 bg-zinc-950"></div>

  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.18),transparent_30%),radial-gradient(circle_at_top_right,rgba(168,85,247,0.18),transparent_28%),radial-gradient(circle_at_bottom,rgba(59,130,246,0.12),transparent_35%)]"></div>

  <div class="absolute inset-0 -z-10 opacity-30 [background-image:linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] [background-size:42px_42px]"></div>

  <div class="mx-auto grid max-w-6xl gap-12 px-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    
    <MotionReveal client:load>
      <div>
        <p class="mb-5 text-l font-semibold uppercase tracking-[0.24em] text-cyan-300">
          Computer Science Master’s Student
        </p>

        <h1 class="max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          I build backend systems and work with data,
          <span class="bg-gradient-to-r from-cyan-300 via-blue-400 to-violet-400 bg-clip-text text-transparent">
            focusing on structure and performance.
          </span>
        </h1>

        <div class="mt-10">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">
            Tech stack
          </p>

          <div class="flex flex-wrap gap-2.5">
            {techStack.map((tech) => (
              <div class="group flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]">
                <img
                  src={`https://cdn.simpleicons.org/${tech.icon}/ffffff`}
                  alt={tech.name}
                  class="h-4 w-4 opacity-80 transition duration-200 group-hover:opacity-100"
                  loading="lazy"
                />
                <span class="text-sm text-zinc-200">{tech.name}</span>
              </div>
            ))}

            <div class="group flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]">
            <span class="text-sm text-zinc-200">etc...</span>
            </div>
          </div>
        </div>

      </div>
    </MotionReveal>

   <MotionReveal client:load delay={0.1}>
  <div class="relative mx-auto w-full max-w-md rounded-[28px] border border-white/10 bg-white/[0.04] p-7 shadow-[0_20px_80px_rgba(0,0,0,0.35)]">
    <div class="absolute inset-0 -z-10 rounded-[28px] bg-gradient-to-br from-cyan-400/8 via-transparent to-violet-400/8"></div>

    <div class="flex flex-col gap-6">
      <div class="flex items-center gap-5">
        <div class="relative h-36 w-36 shrink-0 overflow-hidden rounded-[24px] border border-white/10 bg-white/5">
          <img
            src="/images/profile.jpg"
            alt="portrait"
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 ring-1 ring-cyan-400/20"></div>
        </div>

        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-[0.24em] text-cyan-300/80">
            About me
          </p>

          <h2 class="mt-3 bg-gradient-to-r from-cyan-300 via-blue-400 to-violet-400 bg-clip-text text-3xl font-semibold tracking-tight text-transparent">
            Arne De Peuter
          </h2>

          <p class="mt-2 text-sm text-zinc-400">
            Backend · Data · ML systems
          </p>
        </div>
      </div>

      <div class="border-t border-white/8 pt-6">
        <div class="space-y-4 text-[15px] leading-8 text-zinc-300">
          <p>
            I’m mainly interested in how systems are designed and how data moves through them.
            Most of my work sits between backend development, data engineering, and machine learning.
          </p>
          <p>
            I like working on systems end-to-end, from designing architecture to building the backend
            and experimenting with data and models on top of it.
          </p>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-3">
          <a
            href="https://linkedin.com/in/arne-de-peuter-4055a6267"
            target="_blank"
            rel="noopener noreferrer"
            class="flex justify-center items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-zinc-300 transition hover:-translate-y-0.5 hover:border-blue-400/40"
          >
            LinkedIn
          </a>

          <a
            href="https://github.com/ArneDePeuter"
            target="_blank"
            rel="noopener noreferrer"
            class="flex justify-center items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-zinc-300 transition hover:-translate-y-0.5 hover:border-white/40"
          >
            GitHub
          </a>

          <a
            href="https://leetcode.com/ArneDP"
            target="_blank"
            rel="noopener noreferrer"
            class="flex justify-center items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-zinc-300 transition hover:-translate-y-0.5 hover:border-yellow-400/40"
          >
            LeetCode
          </a>
        </div>
      </div>
    </div>
  </div>
</MotionReveal>
  </div>

  
</section>