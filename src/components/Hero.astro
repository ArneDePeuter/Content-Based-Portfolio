---
import hero from '../content/hero.json';

const { tagline, firstName, lastName, dateOfBirth, location, nationality, languages, profileImage, bio, socialLinks, techStack } = hero;

const dob = new Date(dateOfBirth);
const now = new Date();
const age = now.getFullYear() - dob.getFullYear() - (now < new Date(now.getFullYear(), dob.getMonth(), dob.getDate()) ? 1 : 0);
const dobFormatted = dob.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const details = [
  { label: 'Born', value: `${dobFormatted} (${age})` },
  { label: 'Location', value: location },
  { label: 'Nationality', value: nationality },
  { label: 'Languages', value: languages.map((l) => `${l.name} (${l.level})`).join(', ') },
];
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-20 bg-zinc-950"></div>

  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.18),transparent_30%),radial-gradient(circle_at_top_right,rgba(168,85,247,0.18),transparent_28%),radial-gradient(circle_at_bottom,rgba(59,130,246,0.12),transparent_35%)]"></div>

  <div class="absolute inset-0 -z-10 opacity-30 [background-image:linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] [background-size:42px_42px]"></div>

  <div>
    <div class="fade-in-up">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300 sm:text-base">
        {tagline}
      </p>
    </div>

    <div class="fade-in-up" style="animation-delay: 0.05s">
      <div class="grid grid-cols-[auto_1fr] items-center gap-x-4 gap-y-4 sm:gap-x-8">
        <div class="relative row-span-1 h-9 w-9 shrink-0 overflow-hidden rounded-full border border-white/10 bg-white/5 sm:row-span-2 sm:h-40 sm:w-40 sm:rounded-[24px] sm:shadow-[0_20px_60px_rgba(0,0,0,0.3)]">
          <img
            src={profileImage}
            alt={`${firstName} ${lastName}`}
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 ring-1 ring-cyan-400/20"></div>
        </div>

        <h2 class="min-w-0 bg-gradient-to-r from-cyan-300 via-blue-400 to-violet-400 bg-clip-text text-3xl font-semibold tracking-tight text-transparent sm:text-4xl">
          {firstName} {lastName}
        </h2>

        <div class="col-span-2 max-w-2xl space-y-4 text-sm leading-7 text-zinc-300 sm:col-span-1 sm:col-start-2 sm:text-[15px] sm:leading-8">
          {bio.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </div>

    <div class="fade-in-up" style="animation-delay: 0.08s">
      <dl class="mt-8 space-y-2.5 text-sm">
        {details.map(({ label, value }) => (
          <div class="flex gap-2">
            <dt class="w-24 shrink-0 font-medium text-zinc-500">{label}</dt>
            <dd class="text-zinc-300">{value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="fade-in-up" style="animation-delay: 0.1s">
      <div class="mt-6 flex flex-wrap gap-2">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 rounded-full border border-blue-400/20 bg-blue-400/10 px-4 py-2 text-sm font-medium text-blue-200 transition hover:-translate-y-0.5 hover:border-blue-400/40 hover:bg-blue-400/15"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/cv.pdf"
          download="Arne-De-Peuter-CV.pdf"
          class="flex items-center justify-center gap-1.5 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:-translate-y-0.5 hover:border-cyan-400/40 hover:bg-cyan-400/15"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
          Download CV (PDF)
        </a>
        <a
          href="/llms.txt"
          download="llms.txt"
          class="flex items-center justify-center gap-1.5 rounded-full border border-violet-400/20 bg-violet-400/10 px-4 py-2 text-sm font-medium text-violet-200 transition hover:-translate-y-0.5 hover:border-violet-400/40 hover:bg-violet-400/15"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
          Download llms.txt
        </a>
      </div>
    </div>

    <div class="fade-in-up" style="animation-delay: 0.15s">
      <div class="mt-12 border-t border-white/8 pt-10">
        <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">
          Tech stack
        </p>

        <div id="tech-stack-marquee" class="relative overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)]">
          <div class="marquee-track flex w-max items-center gap-2.5">
            {[...techStack, ...techStack].map((tech) => (
              <div class="group flex shrink-0 items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]">
                <img
                  src={`https://cdn.simpleicons.org/${tech.icon}/ffffff`}
                  alt={tech.name}
                  class="h-4 w-4 shrink-0 opacity-80 transition duration-200 group-hover:opacity-100"
                  loading="lazy"
                />
                <span class="whitespace-nowrap text-sm text-zinc-200">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>

        <div id="tech-stack-full" class="hidden flex-wrap gap-2.5">
          {techStack.map((tech) => (
            <div class="group flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-zinc-300 transition duration-200 hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-white/[0.08]">
              <img
                src={`https://cdn.simpleicons.org/${tech.icon}/ffffff`}
                alt={tech.name}
                class="h-4 w-4 shrink-0 opacity-80 transition duration-200 group-hover:opacity-100"
                loading="lazy"
              />
              <span class="whitespace-nowrap text-sm text-zinc-200">{tech.name}</span>
            </div>
          ))}
        </div>

        <button
          id="tech-stack-toggle"
          type="button"
          aria-expanded="false"
          class="tech-stack-toggle mx-auto mt-4 flex items-center gap-2 text-xs font-medium text-zinc-500 transition duration-200 hover:text-zinc-300"
        >
          <svg
            class="tech-stack-toggle-icon h-3 w-3 transition-transform duration-200"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 7l5 5 5-5" />
          </svg>
          <span id="tech-stack-toggle-label">Expand</span>
          <svg
            class="tech-stack-toggle-icon h-3 w-3 transition-transform duration-200"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 7l5 5 5-5" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .marquee-track {
    animation: marquee 32s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('tech-stack-toggle');
  const marquee = document.getElementById('tech-stack-marquee');
  const full = document.getElementById('tech-stack-full');
  const label = document.getElementById('tech-stack-toggle-label');
  const icons = document.querySelectorAll('.tech-stack-toggle-icon');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    const next = !expanded;

    toggle.setAttribute('aria-expanded', String(next));
    marquee?.classList.toggle('hidden', next);
    full?.classList.toggle('hidden', !next);
    full?.classList.toggle('flex', next);

    if (label) label.textContent = next ? 'Compact' : 'Expand';
    icons.forEach((icon) => {
      (icon as HTMLElement).style.transform = next ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  });
</script>
